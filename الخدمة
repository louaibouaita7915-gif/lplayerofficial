  {q:'ما هي مدة كل جولة في Free Fire؟',opts:['5 دقائق','10 دقائق','15 دقائق','20 دقائق'],ans:1},
  {q:'كم عدد اللاعبين في كل مباراة؟',opts:['30 لاعب','40 لاعب','50 لاعب','60 لاعب'],ans:2},
  {q:'ما اسم مهارة شخصية Alok؟',opts:['Time Turner','Drop the Beat','Camouflage','Riptide Rhythm'],ans:1},
  {q:'أي سلاح يخترق الـ Gloo Wall؟',opts:['AK','MP40','M82B','M1887'],ans:2},
  {q:'ما كلمة الفوز في Free Fire؟',opts:['Victory','Winner','BOOYAH','Champion'],ans:2}
];
let currentQ=0,score=0,answered=false;
function renderQuiz(){const q=questions[currentQ];document.getElementById('qNum').textContent='سؤال '+(currentQ+1);document.getElementById('quizQ').textContent=q.q;const optsEl=document.getElementById('quizOpts');optsEl.innerHTML='';q.opts.forEach((opt,i)=>{const btn=document.createElement('button');btn.className='quiz-opt';btn.textContent=opt;btn.onclick=()=>answerQuiz(i,btn,q.ans);optsEl.appendChild(btn);});answered=false;}
function answerQuiz(i,btn,ans){if(answered)return;answered=true;const btns=document.querySelectorAll('.quiz-opt');btns[ans].classList.add('correct');if(i!==ans){btn.classList.add('wrong');}else{score++;}setTimeout(()=>{currentQ++;if(currentQ<questions.length){renderQuiz();}else{showResult();}},1200);}
function showResult(){document.getElementById('quizOpts').style.display='none';document.getElementById('quizQ').style.display='none';document.querySelector('.quiz-progress').style.display='none';const res=document.getElementById('quizResult');res.style.display='block';let title,desc;if(score===5){title='🏆 أسطورة Free Fire!';desc='مبروك! أنت الأفضل!';}else if(score>=3){title='🔥 لاعب محترف!';desc='أداء رائع! قليل تدريب للقمة!';}else{title='🎮 لاعب واعد!';desc='استمر وستتحسن!';}res.innerHTML=`<div class="result-score">${score}/5</div><div class="result-title">${title}</div><div class="result-desc">${desc}</div><button class="quiz-restart" onclick="restartQuiz()">🔄 حاول مجدداً</button>`;}
function restartQuiz(){currentQ=0;score=0;document.getElementById('quizOpts').style.display='flex';document.getElementById('quizQ').style.display='block';document.querySelector('.quiz-progress').style.display='block';document.getElementById('quizResult').style.display='none';renderQuiz();}
