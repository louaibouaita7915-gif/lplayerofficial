<style>
:root{--fire:#FF4500;--gold:#FFD700;--dark:#0a0a0f;--darker:#050508;--card:#12121e;}
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{background:var(--dark);color:#eee;font-family:'Tajawal',sans-serif;overflow-x:hidden;}
#particles{position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:0;overflow:hidden;}
.particle{position:absolute;border-radius:50%;animation:floatUp linear infinite;opacity:0;}
@keyframes floatUp{0%{transform:translateY(100vh) scale(0);opacity:0;}10%{opacity:1;}90%{opacity:0.6;}100%{transform:translateY(-10vh) scale(1.5);opacity:0;}}
nav{position:fixed;top:0;width:100%;z-index:100;background:linear-gradient(to bottom,#000000cc,transparent);padding:14px 20px;display:flex;justify-content:space-between;align-items:center;backdrop-filter:blur(6px);}
.logo{font-family:'Rajdhani',sans-serif;font-size:1.6rem;color:var(--gold);text-shadow:0 0 15px #FFD70099;}
.nav-links{display:flex;gap:8px;list-style:none;flex-wrap:wrap;font-size:0.78rem;}
.nav-links a{color:#ccc;text-decoration:none;font-weight:700;transition:color 0.3s;}
.nav-links a:hover{color:var(--fire);}
#hero{position:relative;min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:100px 20px 60px;background:radial-gradient(ellipse at 50% 80%,#FF450022 0%,transparent 70%),var(--darker);z-index:1;}
.hero-badge{display:inline-block;background:linear-gradient(135deg,#FF4500,#FF8C00);color:#fff;padding:6px 20px;border-radius:30px;font-size:0.85rem;font-weight:700;margin-bottom:20px;animation:pulse 2s ease-in-out infinite;}
@keyframes pulse{0%,100%{box-shadow:0 0 15px #FF450066;}50%{box-shadow:0 0 35px #FF4500cc;}}
.hero-title{font-family:'Rajdhani',sans-serif;font-size:clamp(3rem,10vw,7rem);font-weight:700;background:linear-gradient(135deg,#FFD700,#FF4500 60%,#FF6B00);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;margin-bottom:10px;}
.hero-subtitle{font-size:clamp(1rem,3vw,1.5rem);color:#aaa;margin-bottom:30px;}
.hero-subtitle span{color:var(--gold);font-weight:900;}
.hero-stats{display:flex;gap:20px;flex-wrap:wrap;justify-content:center;margin:30px 0;}
.stat-box{background:var(--card);border:1px solid #FF450033;border-radius:16px;padding:16px 20px;text-align:center;min-width:100px;}
.stat-num{font-family:'Rajdhani',sans-serif;font-size:2rem;font-weight:700;color:var(--gold);}
.stat-label{font-size:0.8rem;color:#888;}
.cta-btn{display:inline-block;margin-top:10px;padding:14px 40px;background:linear-gradient(135deg,#FF4500,#FF8C00);color:#fff;font-size:1.1rem;font-weight:900;border-radius:50px;text-decoration:none;box-shadow:0 6px 25px #FF450055;transition:transform 0.3s;}
section{position:relative;z-index:1;padding:60px 20px;max-width:1100px;margin:0 auto;}
.section-title{text-align:center;font-family:'Rajdhani',sans-serif;font-size:2.2rem;font-weight:700;margin-bottom:40px;color:#fff;}
.section-title::after{content:'';display:block;width:60px;height:3px;background:linear-gradient(90deg,var(--fire),var(--gold));margin:12px auto 0;border-radius:2px;}
.divider{width:100%;height:1px;background:linear-gradient(90deg,transparent,#FF450044,transparent);margin:10px 0;}
.about-grid{display:grid;grid-template-columns:1fr 1fr;gap:30px;align-items:center;}
.about-img{width:180px;height:180px;border-radius:50%;background:linear-gradient(135deg,#FF4500,#FFD700);display:flex;align-items:center;justify-content:center;font-size:5rem;margin:0 auto;box-shadow:0 0 50px #FF450055;}
.about-text{font-size:1rem;line-height:1.9;color:#bbb;}
.about-text h3{color:var(--gold);font-size:1.4rem;margin-bottom:10px;}
.chars-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:20px;}
.char-card{background:var(--card);border:1px solid #FF450022;border-radius:20px;padding:24px 16px;text-align:center;transition:transform 0.3s,border-color 0.3s;}
.char-card:hover{transform:translateY(-8px);border-color:var(--fire);}
.char-icon{font-size:3rem;margin-bottom:12px;}
.char-name{font-size:1.1rem;font-weight:900;color:var(--gold);margin-bottom:6px;}
.char-role{font-size:0.82rem;color:#888;margin-bottom:12px;}
.char-skill{background:#FF450022;border-radius:10px;padding:8px;font-size:0.78rem;color:#ccc;line-height:1.5;}
.tips-list{display:flex;flex-direction:column;gap:16px;}
.tip-item{background:var(--card);border-right:4px solid var(--fire);border-radius:14px;padding:18px 20px;display:flex;align-items:flex-start;gap:14px;}
.tip-num{font-family:'Rajdhani',sans-serif;font-size:1.8rem;font-weight:700;color:var(--fire);min-width:36px;}
.tip-content h4{font-size:1rem;color:var(--gold);margin-bottom:4px;}
.tip-content p{color:#999;font-size:0.9rem;line-height:1.6;}
.weapons-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(230px,1fr));gap:18px;}
.weapon-card{background:var(--card);border:1px solid #ffffff11;border-radius:16px;padding:20px;transition:transform 0.3s,border-color 0.3s;}
.weapon-card:hover{transform:translateY(-6px);border-color:var(--gold);}
.weapon-header{display:flex;align-items:center;gap:12px;margin-bottom:14px;}
.weapon-icon{font-size:2rem;}
.weapon-name{font-size:1.1rem;font-weight:900;color:#fff;}
.weapon-type{font-size:0.78rem;color:var(--fire);}
.stat-bar{margin-bottom:8px;}
.stat-bar-label{display:flex;justify-content:space-between;font-size:0.78rem;color:#888;margin-bottom:4px;}
.bar-bg{background:#ffffff11;border-radius:4px;height:6px;overflow:hidden;}
.bar-fill{height:100%;border-radius:4px;background:linear-gradient(90deg,var(--fire),var(--gold));}
</style><body>
